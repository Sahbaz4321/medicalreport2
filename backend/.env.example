PORT=5000
NODE_ENV=development

# Optional: configure a real AI provider for explanations and chat
# AI_PROVIDER can be "openai" or "gemini"
#AI_PROVIDER=openai

# For OpenAI
#OPENAI_API_KEY=your_openai_api_key_here
#OPENAI_MODEL=gpt-4o-mini

# For Gemini
# Keep your real key in backend/.env (do not commit it)
GEMINI_API_KEY=AIzaSyBXfBtIOG0c6W1PL8i0hl4mzpAfpcVQRec
GEMINI_MODEL=gemini-1.5-flash
# Tip: For a newer preview model you can also use:
 GEMINI_MODEL=gemini-3-flash-preview

# Timeouts (ms). Increase if AI is slow.
AI_SUMMARY_TIMEOUT_MS=5000
AI_STRUCTURED_TIMEOUT_MS=15000

